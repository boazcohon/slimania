; Engine configuration file.
; It's best edited using the editor UI and not directly, but hand-editing the
; [input] section or window size is safe if you're careful.
;
; SLIMANIA — Phase 1 roguelike prototype.
; Main scene = the title screen. Autoloads (singletons that exist everywhere):
;   SpritePaths — where every PNG lives
;   Moves       — every battle move in the game
;   RunManager  — remembers the current run (HP, level, room, loadout)

config_version=5

[application]

config/name="Slimania"
config/description="A cute roguelike about Goopzz, a green slime with a wooden sword, bonking his way back home. Phase 1 prototype."
run/main_scene="res://scenes/title_screen.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

SpritePaths="*res://scripts/sprite_paths.gd"
Moves="*res://scripts/moves.gd"
RunManager="*res://scripts/run_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

